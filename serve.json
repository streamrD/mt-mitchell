{
  "headers": [
    {
      "source": "**",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}
